      "category": "control_flow"
    },
    {
      "keyword": "{:then}",
      "type": "keyword",
      "description": "{:then} - Handle resolved promise value in await block.",
      "example": "{:then data}Success: {data}{/await}",
      "category": "control_flow"
    },
    {
      "keyword": "{:catch}",
      "type": "keyword",
      "description": "{:catch} - Handle promise rejection in await block.",
      "example": "{:catch error}Error: {error.message}{/await}",
      "category": "control_flow"
    },
    {
      "keyword": "{#key}",
      "type": "keyword",
      "description": "{#key} - Destroy and recreate contents when expression changes.",
      "example": "{#key value}\n  <Component />\n{/key}",
      "category": "control_flow"
    },
    {
