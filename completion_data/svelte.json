      "category": "exports"
    },
    {
      "keyword": "export function",
      "type": "keyword",
      "description": "export function - Export a function that can be called from parent via bind:this.",
      "example": "export function reset() { count = 0; }",
      "category": "exports"
    },
    {
      "keyword": "{#if}",
      "type": "keyword",
      "description": "{#if} - Conditional rendering. Can be combined with {:else if} and {:else}.",
      "example": "{#if condition}Content{/if}",
      "category": "control_flow"
    },
    {
      "keyword": "{:else if}",
      "type": "keyword",
      "description": "{:else if} - Else-if clause in conditional rendering.",
      "example": "{:else if otherCondition}Other content{/if}",
      "category": "control_flow"
    },
    {
      "keyword": "{:else}",
      "type": "keyword",
      "description": "{:else} - Else clause in conditional rendering or await blocks.",
      "example": "{:else}Default content{/if}",
      "category": "control_flow"
    },
    {
      "keyword": "{#each}",
      "type": "keyword",
      "description": "{#each} - Iterate over an array. Use (item, index) for index access.",
      "example": "{#each items as item, i}\n  <p>{i}: {item}</p>\n{/each}",
      "category": "control_flow"
    },
    {
      "keyword": "{#await}",
      "type": "keyword",
      "description": "{#await} - Handle promises with pending, then, and catch states.",
