      "category": "component_structure"
    },
    {
      "keyword": "style",
      "type": "keyword",
      "description": "style - Scoped CSS styles for the component. Automatically scoped to this component only.",
      "example": "<style>\n  h1 { color: blue; }\n</style>",
      "category": "component_structure"
    },
    {
      "keyword": "svelte:head",
      "type": "keyword",
      "description": "svelte:head - Insert elements into document <head>. Useful for title and meta tags.",
      "example": "<svelte:head>\n  <title>Page Title</title>\n</svelte:head>",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:window",
      "type": "keyword",
      "description": "svelte:window - Add event listeners to the window object. Automatically cleaned up.",
      "example": "<svelte:window on:keydown={handleKeydown} />",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:body",
      "type": "keyword",
      "description": "svelte:body - Add event listeners to document.body. Useful for mouseenter/mouseleave.",
      "example": "<svelte:body on:mouseenter={handleMouseEnter} />",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:document",
      "type": "keyword",
      "description": "svelte:document - Add event listeners to the document. For selectionchange, visibilitychange.",
      "example": "<svelte:document on:visibilitychange={handleVisibilityChange} />",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:component",
      "type": "keyword",
      "description": "svelte:component - Dynamically render a component. Use 'this' prop to specify component.",
      "example": "<svelte:component this={CurrentComponent} {...props} />",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:self",
      "type": "keyword",
      "description": "svelte:self - Allows a component to recursively include itself.",
      "example": "<svelte:self {...props} />",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:element",
      "type": "keyword",
      "description": "svelte:element - Dynamically render an HTML element. Use 'this' prop to specify tag name.",
      "example": "<svelte:element this={tag} {...props} />",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:options",
      "type": "keyword",
      "description": "svelte:options - Specify per-component compiler options like immutable or accessors.",
      "example": "<svelte:options immutable={true} />",
      "category": "special_elements"
    },
    {
      "keyword": "svelte:fragment",
      "type": "keyword",
      "description": "svelte:fragment - Allows content to be placed in a named slot without a wrapper element.",
      "example": "<svelte:fragment slot=\"header\">Content</svelte:fragment>",
      "category": "special_elements"
    },
    {
      "keyword": "on:click",
      "type": "keyword",
      "description": "on:click - Click event handler. Add modifiers like preventDefault or stopPropagation.",
      "example": "<button on:click={handleClick}>Click me</button>",
      "category": "event_handlers"
    },
    {
      "keyword": "on:submit",
      "type": "keyword",
      "description": "on:submit - Form submit event handler. Often used with preventDefault modifier.",
      "example": "<form on:submit|preventDefault={handleSubmit}>",
      "category": "event_handlers"
    },
    {
      "keyword": "on:input",
      "type": "keyword",
      "description": "on:input - Input event handler. Fires when input value changes.",
      "example": "<input on:input={handleInput} />",
      "category": "event_handlers"
    },
    {
      "keyword": "on:change",
      "type": "keyword",
      "description": "on:change - Change event handler. Fires when input loses focus after value changed.",
      "example": "<select on:change={handleChange}>",
      "category": "event_handlers"
    },
    {
      "keyword": "bind:value",
      "type": "keyword",
      "description": "bind:value - Two-way binding for input values. Updates variable when input changes.",
      "example": "<input bind:value={name} />",
      "category": "bindings"
    },
    {
      "keyword": "bind:checked",
      "type": "keyword",
      "description": "bind:checked - Two-way binding for checkbox/radio button checked state.",
      "example": "<input type=\"checkbox\" bind:checked={agreed} />",
      "category": "bindings"
    },
    {
      "keyword": "bind:group",
      "type": "keyword",
      "description": "bind:group - Bind radio buttons or checkboxes to the same variable.",
      "example": "<input type=\"radio\" bind:group={selected} value={option} />",
      "category": "bindings"
    },
    {
      "keyword": "bind:this",
      "type": "keyword",
      "description": "bind:this - Get a reference to a DOM element or component instance.",
      "example": "<canvas bind:this={canvas} />",
      "category": "bindings"
    },
    {
      "keyword": "class:",
      "type": "keyword",
      "description": "class: - Conditionally apply CSS classes. Shorthand: class:active={isActive}",
      "example": "<div class:active={isActive}>Content</div>",
      "category": "directives"
    },
    {
      "keyword": "use:",
      "type": "keyword",
      "description": "use: - Apply an action to an element. Actions run when element is created.",
      "example": "<div use:tooltip={{ text: 'Tooltip' }}>Hover me</div>",
      "category": "directives"
    },
    {
      "keyword": "transition:",
      "type": "keyword",
      "description": "transition: - Apply bidirectional transition when element enters/leaves DOM.",
      "example": "<div transition:fade={{ duration: 300 }}>Content</div>",
      "category": "transitions"
    },
    {
      "keyword": "in:",
      "type": "keyword",
      "description": "in: - Apply transition when element enters the DOM.",
      "example": "<div in:fly={{ x: 200, duration: 500 }}>Content</div>",
      "category": "transitions"
    },
    {
      "keyword": "out:",
      "type": "keyword",
      "description": "out: - Apply transition when element leaves the DOM.",
      "example": "<div out:fade={{ duration: 200 }}>Content</div>",
      "category": "transitions"
    },
    {
      "keyword": "animate:",
      "type": "keyword",
      "description": "animate: - Apply animation when element's position changes in a keyed each block.",
      "example": "<div animate:flip={{ duration: 300 }}>Item</div>",
      "category": "transitions"
    },
    {
      "keyword": "let:",
      "type": "keyword",
      "description": "let: - Expose values from a component to its slot content.",
      "example": "<Component let:item>{item.name}</Component>",
      "category": "slots"
    },
    {
      "keyword": "slot",
      "type": "keyword",
      "description": "slot - Define a slot for child content. Can be named with name attribute.",
      "example": "<slot name=\"header\">Default header</slot>",
      "category": "slots"
    },
    {
      "keyword": "$:",
      "type": "keyword",
      "description": "$: - Reactive statement. Runs whenever referenced values change.",
      "example": "$: doubled = count * 2;",
      "category": "reactivity"
    },
    {
      "keyword": "$store",
      "type": "keyword",
      "description": "$store - Auto-subscribe to a store. Automatically unsubscribes on component destroy.",
      "example": "<p>Count: {$count}</p>",
      "category": "stores"
    },
    {
      "keyword": "export let",
      "type": "keyword",
      "description": "export let - Declare a component prop. Can have default values.",
      "example": "export let name = 'World';",
      "category": "props"
    },
    {
      "keyword": "export const",
      "type": "keyword",
      "description": "export const - Export a constant that can be imported by other modules.",
