<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="DvopGitDiffPanel" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">8</property>
    <property name="margin-start">12</property>
    <property name="margin-end">12</property>
    <property name="margin-top">12</property>
    <property name="margin-bottom">12</property>
    <property name="width-request">0</property>
    <property name="hexpand">true</property>
    
    <!-- Header section -->
    <child>
      <object class="GtkBox" id="header_box">
        <property name="orientation">horizontal</property>
        <property name="spacing">8</property>
        <property name="margin-bottom">8</property>
        <child>
          <object class="GtkMenuButton" id="branch_button">
            <property name="label">No repository</property>
            <property name="tooltip-text">Switch branch</property>
            <property name="hexpand">true</property>
            <property name="halign">start</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="refresh_button">
            <property name="icon-name">view-refresh-symbolic</property>
            <property name="tooltip-text">Refresh git status</property>
            <property name="valign">center</property>
            <property name="halign">end</property>
          </object>
        </child>
      </object>
    </child>
    
    <!-- Separator -->
    <child>
      <object class="GtkSeparator">
        <property name="orientation">horizontal</property>
        <property name="margin-bottom">8</property>
      </object>
    </child>
    
    <!-- Commit section -->
    <child>
      <object class="GtkScrolledWindow" id="commit_message_scroller">
        <property name="hscrollbar-policy">never</property>
        <property name="vscrollbar-policy">automatic</property>
        <property name="vexpand">false</property>
        <property name="hexpand">true</property>
        <property name="min-content-height">80</property>
        <property name="max-content-height">150</property>
        <child>
          <object class="GtkTextView" id="commit_message_view">
            <property name="wrap-mode">word-char</property>
            <property name="accepts-tab">false</property>
            <property name="top-margin">6</property>
            <property name="bottom-margin">6</property>
            <property name="left-margin">6</property>
            <property name="right-margin">6</property>
          </object>
        </child>
      </object>
    </child>
    
    <child>
      <object class="GtkButton" id="commit_button">
        <property name="label">Commit</property>
        <property name="tooltip-text">Commit staged changes or push commits</property>
        <property name="hexpand">true</property>
        <property name="margin-bottom">8</property>
        <property name="css-classes">suggested-action</property>
      </object>
    </child>
    
    <!-- Separator -->
    <child>
      <object class="GtkSeparator">
        <property name="orientation">horizontal</property>
        <property name="margin-bottom">8</property>
      </object>
    </child>
    
    <!-- Staged changes section -->
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="spacing">8</property>
        <property name="margin-bottom">4</property>
        <child>
          <object class="GtkLabel" id="staged_label">
            <property name="label">Staged Changes</property>
            <property name="xalign">0.0</property>
            <property name="hexpand">true</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="unstage_all_button">
            <property name="icon-name">list-remove-symbolic</property>
            <property name="tooltip-text">Unstage all changes</property>
            <property name="valign">center</property>
            <property name="halign">end</property>
          </object>
        </child>
      </object>
    </child>
    
    <child>
      <object class="GtkScrolledWindow" id="staged_scroller">
        <property name="hscrollbar-policy">never</property>
        <property name="vscrollbar-policy">automatic</property>
        <property name="vexpand">true</property>
        <property name="hexpand">true</property>
        <property name="min-content-height">100</property>
        <child>
          <object class="GtkListBox" id="staged_files_list">
            <property name="selection-mode">single</property>
            <property name="css-classes">boxed-list</property>
          </object>
        </child>
      </object>
    </child>
    
    <!-- Unstaged changes section -->
    <child>
      <object class="GtkSeparator">
        <property name="orientation">horizontal</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">8</property>
      </object>
    </child>
    
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="spacing">8</property>
        <property name="margin-bottom">4</property>
        <child>
          <object class="GtkLabel" id="unstaged_label">
            <property name="label">Unstaged Changes</property>
            <property name="xalign">0.0</property>
            <property name="hexpand">true</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="revert_all_button">
            <property name="icon-name">edit-undo-symbolic</property>
            <property name="tooltip-text">Revert all unstaged changes</property>
            <property name="valign">center</property>
            <property name="halign">end</property>
            <property name="css-classes">destructive-action</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="stage_all_button">
            <property name="icon-name">list-add-symbolic</property>
            <property name="tooltip-text">Stage all changes</property>
            <property name="valign">center</property>
            <property name="halign">end</property>
          </object>
        </child>
      </object>
    </child>
    
    <child>
      <object class="GtkScrolledWindow" id="files_scroller">
        <property name="hscrollbar-policy">never</property>
        <property name="vscrollbar-policy">automatic</property>
        <property name="vexpand">true</property>
        <property name="hexpand">true</property>
        <child>
          <object class="GtkListBox" id="files_list">
            <property name="selection-mode">single</property>
            <property name="css-classes">boxed-list</property>
          </object>
        </child>
      </object>
    </child>
    
  </template>
</interface>
